{
  "name": "mediarelay",
  "version": "0.1.0",
  "description": "Offline-first health records and care coordination on Stellar",
  "private": true,
  "workspaces": [
    "mobile"
  ],
  "scripts": {
    "test": "jest --runInBand",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage",
    "build": "tsc --project tsconfig.json",
    "dev:node": "ts-node server/index.ts",
    "keygen": "ts-node scripts/keygen.ts",
    "keygen:hierarchy": "ts-node scripts/keygen.ts --hierarchy",
    "mesh:sim": "ts-node scripts/mesh-sim.ts",
    "lint": "eslint 'core/**/*.ts' 'stellar/**/*.ts' 'server/**/*.ts' 'scripts/**/*.ts'"
  },
  "dependencies": {
    "@stellar/stellar-sdk": "^13.1.0",
    "@types/fhir": "^0.0.41",
    "cbor-x": "^1.6.0",
    "tweetnacl": "^1.0.3",
    "tweetnacl-util": "^0.15.1",
    "dotenv": "^16.4.5"
  },
  "devDependencies": {
    "@types/jest": "^29.5.12",
    "@types/node": "^20.14.0",
    "@typescript-eslint/eslint-plugin": "^7.13.0",
    "@typescript-eslint/parser": "^7.13.0",
    "eslint": "^8.57.0",
    "jest": "^29.7.0",
    "ts-jest": "^29.1.5",
    "ts-node": "^10.9.2",
    "typescript": "^5.4.5"
  },
  "jest": {
    "preset": "ts-jest",
    "testEnvironment": "node",
    "roots": [
      "<rootDir>/tests",
      "<rootDir>/core",
      "<rootDir>/stellar"
    ],
    "testMatch": [
      "**/*.test.ts"
    ],
    "collectCoverageFrom": [
      "core/**/*.ts",
      "stellar/**/*.ts",
      "!**/*.d.ts"
    ]
  }
}
